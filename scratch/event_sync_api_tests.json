          "host": [
            "localhost"
          ],
          "port": "5000",
          "path": [
            "api",
            "events",
            "sync-booking"
          ]
        },
        "description": "Expected response: 201 Created. Matches the user by mobile/email, records sync log, saves EventBooking."
      }
    },
