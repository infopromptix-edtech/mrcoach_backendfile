            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"user_name\": \"kamalesh\",\n  \"user_email\": \"2kamalesh0809@gmail.com\",\n  \"verified_mobile_number\": \"+919790852590\",\n  \"event_id\": \"evt_yoga_special_2026\",\n  \"event_title\": \"International Yoga Masterclass\",\n  \"booking_id\": \"bk_web_99831A\",\n  \"website_order_id\": \"order_O1928374\",\n  \"payment_gateway_order_id\": \"pay_order_razor_8812\",\n  \"payment_id\": \"pay_razor_928374619\",\n  \"payment_status\": \"PAID\",\n  \"amount_paid\": 999,\n  \"currency\": \"INR\",\n  \"ticket_quantity\": 2,\n  \"booking_date_time\": \"2026-05-27T10:30:00Z\",\n  \"event_date\": \"2026-06-15\",\n  \"booking_source\": \"website\",\n  \"metadata\": {\n    \"device\": \"Desktop\",\n    \"browser\": \"Chrome\",\n    \"coupon_code\": \"YOGA50\"\n  }\n}"
        },
